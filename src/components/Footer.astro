---
import { Mail, Phone } from "lucide-react";
import { serviceDetails } from "@/data/serviceDetails";
import { domains } from "@/data/domains";
import Logo from "./Logo.astro";
import { SITE } from "@/data/site";
const year = new Date().getFullYear();
---
<footer class="hero-gradient text-primary-foreground">
  <div class="container max-w-6xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10">
      <div>
        <div class="mb-4">
          <Logo className="h-14 md:h-16 w-auto" inverted />
        </div>
        <p class="text-primary-foreground/70 text-sm leading-relaxed">
          Healthcare digital marketing specialists. We help medical practices grow their patient base through proven digital strategies.
        </p>
      </div>

      <div>
        <h4 class="font-display font-bold mb-4">Services</h4>
        <ul class="space-y-2">
          {serviceDetails.slice(0, 6).map((s) => (
            <li><a href={`/services/${s.slug}/`} class="text-sm text-primary-foreground/70 hover:text-primary-foreground transition-colors">{s.title}</a></li>

          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-display font-bold mb-4">Industries</h4>
        <ul class="space-y-2">
          <li><a href="/domains/" class="text-sm text-primary-foreground/70 hover:text-primary-foreground transition-colors">All Industries</a></li>
          {domains.slice(0, 6).map((d) => (
            <li><a href={`/domains/${d.slug}/`} class="text-sm text-primary-foreground/70 hover:text-primary-foreground transition-colors">{d.shortName}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-display font-bold mb-4">Quick Links</h4>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm text-primary-foreground/70 hover:text-primary-foreground transition-colors">Home</a></li>
          <li><a href="/about/" class="text-sm text-primary-foreground/70 hover:text-primary-foreground transition-colors">About Us</a></li>
          <li><a href="/services/" class="text-sm text-primary-foreground/70 hover:text-primary-foreground transition-colors">All Services</a></li>
          <li><a href="/domains/" class="text-sm text-primary-foreground/70 hover:text-primary-foreground transition-colors">Industries</a></li>
          <li><a href="/blog/" class="text-sm text-primary-foreground/70 hover:text-primary-foreground transition-colors">Blog</a></li>
          <li><a href="/contact/" class="text-sm text-primary-foreground/70 hover:text-primary-foreground transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-display font-bold mb-4">Contact</h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-2 text-sm text-primary-foreground/70">
            <Phone className="w-4 h-4 mt-0.5 shrink-0" />
            <a href={`tel:${SITE.phoneIntl}`} class="hover:text-primary-foreground transition-colors">{SITE.phone}</a>
          </li>
          <li class="flex items-start gap-2 text-sm text-primary-foreground/70">
            <Mail className="w-4 h-4 mt-0.5 shrink-0" />
            <a href={`mailto:${SITE.email}`} class="hover:text-primary-foreground transition-colors">{SITE.email}</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-primary-foreground/20 mt-12 pt-8 text-center text-sm text-primary-foreground/50">
      © {year} REGC Digital. All rights reserved.
    </div>
  </div>
</footer>
