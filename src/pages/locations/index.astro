---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { MapPin } from "lucide-react";
import { provinces, cities, locations } from "@/data/locations";
import { breadcrumbList, itemList } from "@/lib/seo";

const title = "Healthcare Marketing Locations | REGC Digital";
const description = "Specialist healthcare marketing across South Africa — from Johannesburg and Cape Town to Bloemfontein, Polokwane and beyond. Find your city or province.";
const path = "/locations/";

const grouped = provinces.map((p) => ({
  province: p,
  cities: cities.filter((c) => c.region === p.region),
}));

const jsonLd = [
  breadcrumbList([
    { name: "Home", path: "/" },
    { name: "Locations", path },
  ]),
  itemList(locations, (l) => ({
    name: l.name,
    url: `/healthcare-marketing-${l.slug}/`,
    description: l.intro,
  })),
];
---
<BaseLayout {title} {description} {jsonLd} canonicalPath={path}>
  <section class="hero-gradient text-primary-foreground py-20">
    <div class="container max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">Healthcare Marketing Across South Africa</h1>
      <p class="text-lg text-primary-foreground/85">Specialist digital marketing for medical practices in {cities.length} cities across {provinces.length} provinces.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="container max-w-5xl mx-auto px-4 space-y-12">
      {grouped.map(({ province, cities: provinceCities }) => (
        <div>
          <div class="flex items-center justify-between flex-wrap gap-3 mb-6">
            <a href={`/healthcare-marketing-${province.slug}/`} class="font-display text-2xl font-bold text-foreground hover:text-secondary transition-colors flex items-center gap-2">
              <MapPin className="w-5 h-5 text-secondary" /> {province.name}
            </a>
            <a href={`/healthcare-marketing-${province.slug}/`} class="text-sm text-secondary font-semibold hover:underline">View province →</a>
          </div>
          <p class="text-sm text-muted-foreground mb-4">{province.intro}</p>
          {provinceCities.length > 0 && (
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
              {provinceCities.map((c) => (
                <a href={`/healthcare-marketing-${c.slug}/`} class="bg-card border border-border rounded-lg px-4 py-3 hover:border-secondary hover:shadow-md transition-all">
                  <p class="font-display font-semibold text-foreground text-sm">{c.name}</p>
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
