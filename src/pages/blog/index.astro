---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { ArrowRight } from "lucide-react";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const title = "Healthcare Marketing Insights | REGC Digital Blog";
const description = "Practical guides, strategies, and insights on digital marketing for South African medical practices.";
---
<BaseLayout {title} {description}>
  <section class="hero-gradient text-primary-foreground py-20">
    <div class="container max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">Insights & Guides</h1>
      <p class="text-lg text-primary-foreground/85">Practical healthcare marketing advice for South African practices.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="container max-w-5xl mx-auto px-4">
      {posts.length === 0 ? (
        <p class="text-center text-muted-foreground">No posts yet — check back soon.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}/`} class="group bg-card border border-border rounded-xl p-6 hover:shadow-lg hover:border-secondary transition-all flex flex-col">
              <div class="text-4xl mb-3">{post.data.heroEmoji}</div>
              <span class="text-xs uppercase tracking-wide text-secondary font-semibold mb-2">{post.data.category}</span>
              <h2 class="font-display text-xl font-bold text-foreground mb-2 group-hover:text-secondary transition-colors">{post.data.title}</h2>
              <p class="text-sm text-muted-foreground flex-1">{post.data.description}</p>
              <div class="mt-4 flex items-center justify-between text-xs text-muted-foreground">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("en-ZA", { year: "numeric", month: "long", day: "numeric" })}
                </time>
                <span class="inline-flex items-center gap-1 text-secondary font-semibold">
                  Read <ArrowRight className="w-3 h-3" />
                </span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
