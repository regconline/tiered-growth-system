---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CheckCircle2, Heart, Target, Users } from "lucide-react";
import { breadcrumbList } from "@/lib/seo";

const title = "About Us | REGC Digital";
const description = "We're a team of healthcare marketing specialists in South Africa. Learn how REGC Digital helps medical practices grow ethically and sustainably.";
const path = "/about/";
const jsonLd = [
  breadcrumbList([
    { name: "Home", path: "/" },
    { name: "About", path },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    name: title,
    description,
    url: path,
  },
];
---
<BaseLayout {title} {description} {jsonLd} canonicalPath={path}>
  <section class="hero-gradient text-primary-foreground py-20">
    <div class="container max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">About REGC Digital</h1>
      <p class="text-lg text-primary-foreground/85">Healthcare marketing specialists serving South African practices.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="container max-w-4xl mx-auto px-4 prose prose-lg">
      <p>REGC Digital was founded with one mission: to help South African healthcare practices grow ethically through proven, transparent digital marketing.</p>
      <p>We understand healthcare. We understand the HPCSA's advertising rules. We understand that patients are not customers — they are people seeking trusted care. Every campaign we build, every word we write, and every page we design respects that.</p>
      <h2>Why we exist</h2>
      <p>Most marketing agencies treat medical practices like any other small business. We don't. We've spent years working with GPs, dentists, specialists, and allied health professionals — learning what works, what doesn't, and what's compliant.</p>
    </div>
  </section>

  <section class="py-16 bg-muted/30">
    <div class="container max-w-6xl mx-auto px-4">
      <h2 class="font-display text-3xl font-bold text-center mb-12">Our values</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-card border border-border rounded-xl p-6 text-center">
          <Heart className="w-10 h-10 text-secondary mx-auto mb-3" />
          <h3 class="font-display font-bold text-lg mb-2">Patient-first</h3>
          <p class="text-sm text-muted-foreground">We market your practice the way patients want to be spoken to — clearly, kindly, and honestly.</p>
        </div>
        <div class="bg-card border border-border rounded-xl p-6 text-center">
          <CheckCircle2 className="w-10 h-10 text-secondary mx-auto mb-3" />
          <h3 class="font-display font-bold text-lg mb-2">Ethical & compliant</h3>
          <p class="text-sm text-muted-foreground">All work follows HPCSA, POPIA, and platform advertising guidelines.</p>
        </div>
        <div class="bg-card border border-border rounded-xl p-6 text-center">
          <Target className="w-10 h-10 text-secondary mx-auto mb-3" />
          <h3 class="font-display font-bold text-lg mb-2">Results-focused</h3>
          <p class="text-sm text-muted-foreground">We measure what matters: enquiries, bookings, and patient lifetime value.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
