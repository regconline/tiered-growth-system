---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/react/ContactForm.tsx";
import { Mail, Phone, MessageCircle } from "lucide-react";
import { SITE } from "@/data/site";
import { breadcrumbList } from "@/lib/seo";

const title = "Contact Us | REGC Digital";
const description = "Get in touch with REGC Digital — book a free healthcare marketing consultation by WhatsApp, email or phone.";
const path = "/contact/";
const jsonLd = [
  breadcrumbList([
    { name: "Home", path: "/" },
    { name: "Contact", path },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: title,
    description,
    url: new URL(path, SITE.url).toString(),
  },
];
---
<BaseLayout {title} {description} {jsonLd} canonicalPath={path}>
  <section class="hero-gradient text-primary-foreground py-20">
    <div class="container max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">Let's talk</h1>
      <p class="text-lg text-primary-foreground/85">Book a free, no-obligation consultation. We'll respond within one business day.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="container max-w-6xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <ContactForm client:load />
      </div>
      <aside class="space-y-4">
        <a href={`https://wa.me/${SITE.whatsapp}`} target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 bg-card border border-border rounded-xl p-5 hover:border-secondary transition-colors">
          <MessageCircle className="w-6 h-6 text-[#25D366] mt-0.5 shrink-0" />
          <div>
            <h3 class="font-display font-bold text-foreground">WhatsApp</h3>
            <p class="text-sm text-muted-foreground">Fastest way to reach us</p>
            <p class="text-sm font-semibold text-primary mt-1">{SITE.phone}</p>
          </div>
        </a>
        <a href={`tel:${SITE.phoneIntl}`} class="flex items-start gap-3 bg-card border border-border rounded-xl p-5 hover:border-secondary transition-colors">
          <Phone className="w-6 h-6 text-secondary mt-0.5 shrink-0" />
          <div>
            <h3 class="font-display font-bold text-foreground">Phone</h3>
            <p class="text-sm text-muted-foreground">Mon–Fri, 8:00–17:00</p>
            <p class="text-sm font-semibold text-primary mt-1">{SITE.phone}</p>
          </div>
        </a>
        <a href={`mailto:${SITE.email}`} class="flex items-start gap-3 bg-card border border-border rounded-xl p-5 hover:border-secondary transition-colors">
          <Mail className="w-6 h-6 text-secondary mt-0.5 shrink-0" />
          <div>
            <h3 class="font-display font-bold text-foreground">Email</h3>
            <p class="text-sm text-muted-foreground">We reply within 1 business day</p>
            <p class="text-sm font-semibold text-primary mt-1">{SITE.email}</p>
          </div>
        </a>
      </aside>
    </div>
  </section>
</BaseLayout>
