---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ArrowRight, MapPin, CheckCircle2 } from "lucide-react";
import { locations, cities, provinces } from "@/data/locations";
import { serviceDetails } from "@/data/serviceDetails";
import { domains } from "@/data/domains";
import { SITE } from "@/data/site";

export async function getStaticPaths() {
  return locations.map((loc) => ({ params: { location: loc.slug }, props: { loc } }));
}

const { loc } = Astro.props;

const path = `/healthcare-marketing-${loc.slug}/`;
const title = `Healthcare Marketing in ${loc.name} | REGC Digital`;
const description = `Specialist healthcare digital marketing for medical practices in ${loc.name}, South Africa — websites, SEO, Google Ads, social media and reputation management.`;

const featuredServices = serviceDetails.slice(0, 6);
const sameRegion = cities.filter((c) => c.region === loc.region && c.slug !== loc.slug).slice(0, 6);
const otherProvinces = provinces.filter((p) => p.slug !== loc.slug).slice(0, 5);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": new URL(path, SITE.url).toString() + "#localbusiness",
    name: `${SITE.name} — ${loc.name}`,
    url: new URL(path, SITE.url).toString(),
    telephone: SITE.phoneIntl,
    email: SITE.email,
    priceRange: "$$",
    description,
    areaServed: { "@type": "Place", name: `${loc.name}, South Africa` },
    address: { "@type": "PostalAddress", addressRegion: loc.region, addressCountry: "ZA" },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: SITE.url },
      { "@type": "ListItem", position: 2, name: "Locations", item: new URL("/locations/", SITE.url).toString() },
      { "@type": "ListItem", position: 3, name: loc.name, item: new URL(path, SITE.url).toString() },
    ],
  },
];
---
<BaseLayout {title} {description} {jsonLd} canonicalPath={path}>
  <section class="hero-gradient text-primary-foreground py-16">
    <div class="container max-w-4xl mx-auto px-4">
      <nav class="text-sm text-primary-foreground/70 mb-4">
        <a href="/locations/" class="hover:text-primary-foreground">← All Locations</a>
      </nav>
      <div class="flex items-center gap-3 mb-4">
        <MapPin className="w-8 h-8 text-secondary" />
        <span class="text-sm uppercase tracking-wider text-primary-foreground/70">{loc.type === "province" ? "Province" : "City"} · {loc.region}</span>
      </div>
      <h1 class="font-display text-3xl md:text-5xl font-bold mb-4">Healthcare Marketing in {loc.name}</h1>
      <p class="text-lg md:text-xl text-primary-foreground/85 max-w-2xl">{loc.intro}</p>
      {loc.population && <p class="text-sm text-primary-foreground/60 mt-3">{loc.population}</p>}
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div class="container max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
        <div class="lg:col-span-2">
          <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground mb-4">The {loc.name} medical landscape</h2>
          <p class="text-foreground leading-relaxed mb-4">{loc.medicalContext}</p>
          <h3 class="font-display text-xl font-bold text-foreground mt-8 mb-3">Why local matters in {loc.name}</h3>
          <p class="text-foreground leading-relaxed">{loc.whyLocal}</p>
        </div>
        <aside class="bg-card border border-border rounded-2xl p-6 h-fit">
          <h3 class="font-display font-bold text-foreground mb-3 flex items-center gap-2">
            <MapPin className="w-4 h-4 text-secondary" /> Areas we serve
          </h3>
          <ul class="space-y-2">
            {loc.areas.map((a) => (
              <li class="flex items-start gap-2 text-sm text-muted-foreground">
                <CheckCircle2 className="w-4 h-4 mt-0.5 shrink-0 text-secondary" /><span>{a}</span>
              </li>
            ))}
          </ul>
        </aside>
      </div>

      <div class="mb-12">
        <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground mb-2">Our services for {loc.name} practices</h2>
        <p class="text-muted-foreground mb-6">Every service below is delivered with {loc.name}-specific local SEO, geo-targeted ads, and patient demographics in mind.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {featuredServices.map((s) => (
            <a href={`/services/${s.slug}/`} class="bg-card border border-border rounded-xl p-5 hover:shadow-md hover:border-secondary transition-all">
              <div class="text-2xl mb-2">{s.icon}</div>
              <h3 class="font-display font-bold text-foreground mb-1">{s.title}</h3>
              <p class="text-xs text-muted-foreground line-clamp-2">{s.tagline}</p>
            </a>
          ))}
        </div>
        <div class="mt-4 text-sm">
          <a href="/services/" class="text-secondary font-semibold hover:underline inline-flex items-center gap-1">
            See all services <ArrowRight className="w-4 h-4" />
          </a>
        </div>
      </div>

      <div class="mb-12">
        <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground mb-2">Specialities we serve in {loc.name}</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-6">
          {domains.slice(0, 8).map((d) => (
            <a href={`/domains/${d.slug}/`} class="bg-card border border-border rounded-lg p-3 text-center hover:border-secondary transition-colors">
              <div class="text-2xl mb-1">{d.emoji}</div>
              <p class="text-xs font-semibold text-foreground">{d.shortName}</p>
            </a>
          ))}
        </div>
      </div>

      {sameRegion.length > 0 && (
        <div class="mb-12">
          <h2 class="font-display text-xl md:text-2xl font-bold text-foreground mb-4">Other {loc.region} locations</h2>
          <div class="flex flex-wrap gap-2">
            {sameRegion.map((c) => (
              <a href={`/healthcare-marketing-${c.slug}/`} class="text-sm bg-card border border-border rounded-full px-4 py-1.5 hover:border-secondary transition-colors">
                {c.name}
              </a>
            ))}
          </div>
        </div>
      )}

      {loc.type === "city" && (
        <div class="mb-12">
          <h2 class="font-display text-xl md:text-2xl font-bold text-foreground mb-4">Browse by province</h2>
          <div class="flex flex-wrap gap-2">
            {otherProvinces.map((p) => (
              <a href={`/healthcare-marketing-${p.slug}/`} class="text-sm bg-card border border-border rounded-full px-4 py-1.5 hover:border-secondary transition-colors">
                {p.name}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <section class="py-16 hero-gradient text-primary-foreground">
    <div class="container max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold mb-4">Grow your {loc.name} practice with REGC Digital</h2>
      <p class="text-primary-foreground/85 mb-6">Book a free, no-obligation consultation tailored to {loc.name}'s patient market.</p>
      <a href="/contact/" class="inline-flex items-center gap-2 bg-secondary text-secondary-foreground px-6 py-3 rounded-lg font-semibold hover:bg-secondary/90 transition-colors">
        Book a free consultation <ArrowRight className="w-4 h-4" />
      </a>
    </div>
  </section>
</BaseLayout>
