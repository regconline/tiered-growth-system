---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ArrowRight, CheckCircle2, Sparkles, Star, Users, TrendingUp } from "lucide-react";
import { serviceDetails } from "@/data/serviceDetails";
import { domains } from "@/data/domains";
import { SITE } from "@/data/site";

const title = "REGC Digital — Healthcare Marketing in South Africa";
const description = "Specialist healthcare marketing for South African medical practices. Websites, SEO, ads, social, reputation — done by people who understand healthcare.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: SITE.name,
  url: SITE.url,
  telephone: SITE.phoneIntl,
  email: SITE.email,
  areaServed: "ZA",
  description,
};
---
<BaseLayout {title} {description} {jsonLd} canonicalPath="/">
  <section class="hero-gradient text-primary-foreground">
    <div class="container max-w-6xl mx-auto px-4 py-20 md:py-28">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 bg-white/10 backdrop-blur px-3 py-1 rounded-full text-sm mb-6">
          <Sparkles className="w-4 h-4" /> Specialist healthcare marketing
        </span>
        <h1 class="font-display text-4xl md:text-6xl font-bold mb-6 leading-tight">
          Help more patients find your practice.
        </h1>
        <p class="text-lg md:text-xl text-primary-foreground/85 mb-8 leading-relaxed">
          REGC Digital builds websites, runs ads, and grows reviews for South African medical practices — so the right patients can find you and book.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/contact/" class="inline-flex items-center justify-center gap-2 bg-secondary text-secondary-foreground px-6 py-3 rounded-lg font-semibold hover:bg-secondary/90 transition-colors">
            Book a free consultation <ArrowRight className="w-4 h-4" />
          </a>
          <a href="/services/" class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur border border-white/20 px-6 py-3 rounded-lg font-semibold hover:bg-white/20 transition-colors">
            See services
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-card border-b border-border">
    <div class="container max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div><Users className="w-8 h-8 mx-auto text-secondary mb-2" /><p class="font-display text-3xl font-bold text-primary">50+</p><p class="text-sm text-muted-foreground">Practices served</p></div>
        <div><TrendingUp className="w-8 h-8 mx-auto text-secondary mb-2" /><p class="font-display text-3xl font-bold text-primary">3×</p><p class="text-sm text-muted-foreground">Avg. enquiry growth</p></div>
        <div><Star className="w-8 h-8 mx-auto text-secondary mb-2" /><p class="font-display text-3xl font-bold text-primary">4.9</p><p class="text-sm text-muted-foreground">Client rating</p></div>
        <div><CheckCircle2 className="w-8 h-8 mx-auto text-secondary mb-2" /><p class="font-display text-3xl font-bold text-primary">17</p><p class="text-sm text-muted-foreground">Specialities served</p></div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container max-w-6xl mx-auto px-4">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-4">Everything your practice needs to grow online</h2>
        <p class="text-muted-foreground">Choose what you need — from a single service to a complete digital partnership.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {serviceDetails.map((s) => (
          <a href={`/services/${s.slug}/`} class="group bg-card border border-border rounded-xl p-6 hover:shadow-lg hover:border-secondary transition-all">
            <div class="text-3xl mb-3">{s.icon}</div>
            <h3 class="font-display text-lg font-bold text-foreground mb-2 group-hover:text-secondary transition-colors">{s.title}</h3>
            <p class="text-sm text-muted-foreground line-clamp-3">{s.intro}</p>
            <div class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-secondary">
              Learn more <ArrowRight className="w-4 h-4" />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-muted/30">
    <div class="container max-w-6xl mx-auto px-4">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-4">Built for healthcare specialities</h2>
        <p class="text-muted-foreground">We tailor strategies to the unique patient journey and ethical guidelines of each speciality.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {domains.map((d) => (
          <a href={`/domains/${d.slug}/`} class="bg-card border border-border rounded-lg p-4 text-center hover:shadow-md hover:border-secondary transition-all">
            <div class="text-3xl mb-2">{d.emoji}</div>
            <p class="font-display font-semibold text-sm text-foreground">{d.shortName}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 hero-gradient text-primary-foreground">
    <div class="container max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-4">Ready to grow your practice?</h2>
      <p class="text-primary-foreground/85 mb-8 text-lg">Book a free, no-obligation consultation. We'll review your current digital presence and recommend a clear next step.</p>
      <a href="/contact/" class="inline-flex items-center gap-2 bg-secondary text-secondary-foreground px-6 py-3 rounded-lg font-semibold hover:bg-secondary/90 transition-colors">
        Get started <ArrowRight className="w-4 h-4" />
      </a>
    </div>
  </section>
</BaseLayout>
