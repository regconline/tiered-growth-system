---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ArrowRight } from "lucide-react";
import { serviceDetails } from "@/data/serviceDetails";
import { breadcrumbList, itemList } from "@/lib/seo";

const title = "Healthcare Marketing Services | REGC Digital";
const description = "Full-service healthcare digital marketing: websites, SEO, Google Ads, social media, reputation, photography and more — built for South African medical practices.";
const path = "/services/";
const jsonLd = [
  breadcrumbList([
    { name: "Home", path: "/" },
    { name: "Services", path },
  ]),
  itemList(serviceDetails, (s) => ({
    name: s.title,
    url: `/services/${s.slug}/`,
    description: s.tagline,
  })),
];
---
<BaseLayout {title} {description} {jsonLd} canonicalPath={path}>
  <section class="hero-gradient text-primary-foreground py-20">
    <div class="container max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">Our Services</h1>
      <p class="text-lg text-primary-foreground/85">Pick a single service or combine them into a complete digital partnership.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="container max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {serviceDetails.map((s) => (
          <a href={`/services/${s.slug}/`} class="group bg-card border border-border rounded-xl p-6 hover:shadow-lg hover:border-secondary transition-all flex flex-col">
            <div class="text-3xl mb-3">{s.icon}</div>
            <h2 class="font-display text-xl font-bold text-foreground mb-2 group-hover:text-secondary transition-colors">{s.title}</h2>
            <p class="text-sm text-muted-foreground flex-1">{s.tagline}</p>
            <div class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-secondary">
              View packages <ArrowRight className="w-4 h-4" />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
