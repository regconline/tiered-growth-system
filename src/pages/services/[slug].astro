---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TierCard from "@/components/TierCard.astro";
import { ArrowRight, CheckCircle2 } from "lucide-react";
import { serviceDetails } from "@/data/serviceDetails";
import { SITE } from "@/data/site";

export async function getStaticPaths() {
  return serviceDetails.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;

const title = `${service.title} | REGC Digital`;
const description = service.tagline;
const path = `/services/${service.slug}/`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: service.title,
    description: service.description,
    provider: { "@type": "Organization", name: SITE.name, url: SITE.url },
    areaServed: "ZA",
    url: new URL(path, SITE.url).toString(),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: SITE.url },
      { "@type": "ListItem", position: 2, name: "Services", item: new URL("/services/", SITE.url).toString() },
      { "@type": "ListItem", position: 3, name: service.title, item: new URL(path, SITE.url).toString() },
    ],
  },
];
---
<BaseLayout {title} {description} {jsonLd} canonicalPath={path}>
  <section class="hero-gradient text-primary-foreground py-16">
    <div class="container max-w-4xl mx-auto px-4">
      <nav class="text-sm text-primary-foreground/70 mb-4">
        <a href="/services/" class="hover:text-primary-foreground">← All Services</a>
      </nav>
      <div class="flex items-center gap-4 mb-4">
        <span class="text-5xl">{service.icon}</span>
        <h1 class="font-display text-3xl md:text-5xl font-bold">{service.title}</h1>
      </div>
      <p class="text-lg md:text-xl text-primary-foreground/85 max-w-2xl">{service.tagline}</p>
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div class="container max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">
        <div class="lg:col-span-2 prose prose-lg max-w-none">
          <p class="text-foreground leading-relaxed">{service.description}</p>
        </div>
        <div class="bg-card border border-border rounded-2xl p-6">
          <h2 class="font-display text-lg font-bold text-foreground mb-3">Why this matters</h2>
          <p class="text-sm text-muted-foreground leading-relaxed">{service.whyItMatters}</p>
        </div>
      </div>

      <div class="mb-12">
        <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground mb-2">What's included</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-6">
          {service.features.map((f: string) => (
            <div class="flex items-start gap-3 bg-card border border-border rounded-lg p-4">
              <CheckCircle2 className="w-5 h-5 text-secondary mt-0.5 shrink-0" />
              <span class="text-sm text-foreground">{f}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="mb-12">
        <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground mb-2">Our process</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mt-6">
          {service.process.map((p: any, idx: number) => (
            <div class="bg-card border border-border rounded-xl p-5">
              <div class="text-xs font-bold text-secondary mb-1">STEP {idx + 1}</div>
              <h3 class="font-display font-bold text-foreground mb-2">{p.step}</h3>
              <p class="text-sm text-muted-foreground">{p.description}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground mb-2">Pricing & tiers</h2>
        <p class="text-muted-foreground mb-6">Three transparent options to match your stage and budget.</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {service.tiers.map((t: any) => <TierCard {...t} />)}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-muted/30">
    <div class="container max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground mb-4">Not sure which tier is right?</h2>
      <p class="text-muted-foreground mb-6">Book a free consultation and we'll recommend the best fit for your practice.</p>
      <a href="/contact/" class="inline-flex items-center gap-2 bg-secondary text-secondary-foreground px-6 py-3 rounded-lg font-semibold hover:bg-secondary/90 transition-colors">
        Talk to us <ArrowRight className="w-4 h-4" />
      </a>
    </div>
  </section>
</BaseLayout>
