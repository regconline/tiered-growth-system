---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ArrowRight } from "lucide-react";
import { domains } from "@/data/domains";
import { breadcrumbList, itemList } from "@/lib/seo";

const title = "Healthcare Specialities We Serve | REGC Digital";
const description = "Specialised digital marketing for GPs, dentists, dermatologists, paediatricians, physiotherapists and more across South Africa.";
const path = "/domains/";
const jsonLd = [
  breadcrumbList([
    { name: "Home", path: "/" },
    { name: "Industries", path },
  ]),
  itemList(domains, (d) => ({
    name: d.fullName,
    url: `/domains/${d.slug}/`,
    description: d.heroSubheading,
  })),
];
---
<BaseLayout {title} {description} {jsonLd} canonicalPath={path}>
  <section class="hero-gradient text-primary-foreground py-20">
    <div class="container max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">Healthcare Specialities</h1>
      <p class="text-lg text-primary-foreground/85">Tailored marketing strategies for {domains.length} medical specialities.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="container max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {domains.map((d) => (
          <a href={`/domains/${d.slug}/`} class="group bg-card border border-border rounded-xl p-6 hover:shadow-lg hover:border-secondary transition-all flex flex-col">
            <div class="text-4xl mb-3">{d.emoji}</div>
            <h2 class="font-display text-xl font-bold text-foreground mb-2 group-hover:text-secondary transition-colors">{d.fullName}</h2>
            <p class="text-sm text-muted-foreground flex-1">{d.heroSubheading}</p>
            <div class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-secondary">
              Learn more <ArrowRight className="w-4 h-4" />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
